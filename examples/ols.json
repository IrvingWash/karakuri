{
	"$schema": "https://raw.githubusercontent.com/DanielGavin/ols/master/misc/ols.schema.json",
	"checker_args": "-warnings-as-errors -vet-unused-variables -vet-unused-imports -vet-tabs -vet-style -vet-semicolon -vet-cast",
	"collections": [
		{
			"name": "kmath",
			"path": "../libs/kmath"
		},
		{
			"name": "kutils",
			"path": "../libs/kutils"
		},
		{
			"name": "karakuri",
			"path": "../karakuri"
		}
	],
	"enable_format": true,
	"enable_semantic_tokens": true,
	"enable_document_symbols": true,
	"enable_hover": true,
	"enable_snippets": true
}
